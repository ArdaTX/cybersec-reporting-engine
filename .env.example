# =============================================================================
# CyberSec Reporting Engine - Environment Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Python path for DOCX generation (use venv path if needed) ----------------
PYTHON_PATH=python3

# --- Puppeteer/Chrome path (auto-detected if not set) ------------------------
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# --- Output configuration overrides ------------------------------------------
# OUTPUT_DIR=./output
# OUTPUT_FORMATS=md,html,pdf,docx

# --- Branding defaults -------------------------------------------------------
# DEFAULT_THEME=enterprise-dark
# COMPANY_NAME=CyberSec Inc.

# --- Report metadata ---------------------------------------------------------
# REPORT_AUTHOR=Security Assessment Team
# REPORT_CLASSIFICATION=CONFIDENTIAL
