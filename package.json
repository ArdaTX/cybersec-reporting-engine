{
  "name": "cybersec-reporting-engine",
  "version": "1.0.0",
  "description": "CyberSec Reporting Engine - Convert security findings into professional multi-format reports",
  "type": "module",
  "main": "outputs/orchestrator.js",
  "bin": {
    "cybersec-report": "./cli.js"
  },
  "scripts": {
    "start": "node cli.js",
    "generate": "node cli.js generate",
    "validate": "node cli.js validate",
    "theme": "node cli.js theme",
    "template": "node cli.js template",
    "init": "node cli.js init",
    "serve": "node cli.js serve",
    "install:global": "bash install.sh --global",
    "install:dev": "bash install.sh --dev",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint outputs/ cli.js"
  },
  "keywords": [
    "cybersecurity",
    "reporting",
    "pentest",
    "vulnerability",
    "assessment",
    "markdown",
    "pdf",
    "docx",
    "html"
  ],
  "author": "CyberSec Team",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "commander": "^12.1.0",
    "glob": "^10.4.1",
    "highlight.js": "^11.9.0",
    "jsdom": "^24.1.0",
    "jsonschema": "^1.4.1",
    "marked": "^12.0.2",
    "marked-highlight": "^2.1.3",
    "mermaid": "^10.9.1",
    "puppeteer": "^22.12.1",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  }
}
